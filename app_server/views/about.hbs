<!DOCTYPE html>
<!-- Website template by freewebsitetemplates.com -->
<html>
<head>
	<meta charset="UTF-8">
	<title>About - Travlr Getaways</title>
	<link rel="stylesheet" href="css/style.css" type="text/css">
</head>
<body>
	<div id="background">
		<div id="page">
			{{> header}}
			<div id="contents">
				<div class="box">
					<div>
						<div class="body">
							<h1>About</h1>
							<h2>{{heading}}</h2>
							{{#each sections}}
								<p>{{this.body}}</p>
							{{/each}}
							<hr>
							<div class="ads">
								{{#each adsHighlights}}
									<h2>{{this.title}}</h2>
									<p>{{this.body}}</p>
								{{/each}}
							</div>
							{{#each extraHighlights}}
								<h2>{{this.title}}</h2>
								<p>{{this.body}}</p>
							{{/each}}
						</div>
					</div>
				</div>
			</div>
		</div>
		{{> footer}}
	</div>
</body>
</html>
